include ../../content/hero-content.pug


section.hero
  h1.u-sr-only= hero.a11y.title
  h2.u-sr-only= hero.a11y.heading

  .hero__rectangle.hero__rectangle--1

  .hero__rectangle.hero__rectangle--2

  .hero__container.container.container--sm
    .hero__card
      .hero__flex
        .hero__flex-1
          .hero__title(aria-hidden='true')
            img.hero__wave(
                alt=hero.a11y.wave
                src="/svgs/hand.svg")

            span= hero.heading

          .hero__name(aria-hidden='true')
            = hero.name

          p.hero__text(replace-exp-years)
            = hero.text

          .hero__actions
            each val, key in hero.actions
              a.btn(
                  aria-label= val.ariaLabel
                  download=key === 'resume' && val.fileName
                  href= val.url
                  target=key !== 'resume' && '_blank')
                span(aria-hidden='true')
                  if key === 'github'
                    include ../../../svgs/github.svg
                  else if key === 'gitlab'
                    include ../../../svgs/gitlab.svg
                  else if key === 'linkedIn'
                    include ../../../svgs/linked-in.svg
                  else if key === 'resume'
                    include ../../../svgs/resume.svg

        .hero__flex-2
          img.hero__img(
              role="presentation"
              src='/imgs/profile.jpg')
